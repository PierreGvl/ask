# --- Base de données (PostgreSQL + pgvector) ---
# En local avec docker compose : voir docker-compose.yml
POSTGRES_USER=winetech
POSTGRES_PASSWORD=changeme
POSTGRES_DB=askwinetech
DATABASE_URL=postgresql://winetech:changeme@localhost:5432/askwinetech

# --- Auth.js ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET=
# URL publique de l'app (https://... en prod)
AUTH_URL=http://localhost:3000

# --- Mistral ---
MISTRAL_API_KEY=
CHAT_MODEL=mistral-large-latest
TITLE_MODEL=mistral-small-latest
EMBED_MODEL=mistral-embed

# --- RAG ---
# Distance cosine maximale acceptée (1 - similarité). 0.70 ≈ similarité 0.30
RAG_MAX_DISTANCE=0.70
RAG_TOP_K=8

# --- Multi-tenant ---
# Domaine racine pour le routing par sous-domaine (winetech.ask.fr → 'winetech').
APP_BASE_DOMAIN=ask.fr
# Projet servi sur le domaine apex, www et en dev local.
DEFAULT_PROJECT_SLUG=winetech

# --- Recherche web de secours (souveraine EU) ---
# none | brave | searxng
WEB_SEARCH_PROVIDER=none
# Brave Search API (si WEB_SEARCH_PROVIDER=brave)
BRAVE_API_KEY=
# Instance SearxNG auto-hébergée (si WEB_SEARCH_PROVIDER=searxng)
SEARXNG_URL=

# --- Rate-limiting (requêtes/minute, 0 = désactivé) ---
WIDGET_RATE_LIMIT_PER_MIN=30
GUEST_RATE_LIMIT_PER_MIN=20

# --- Facturation Stripe (optionnel ; webhook /api/billing/webhook) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
