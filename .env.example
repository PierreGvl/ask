# --- Base de données (PostgreSQL + pgvector) ---
# En local avec docker compose : voir docker-compose.yml
POSTGRES_USER=winetech
POSTGRES_PASSWORD=changeme
POSTGRES_DB=askwinetech
DATABASE_URL=postgresql://winetech:changeme@localhost:5432/askwinetech

# --- Auth.js ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET=
# URL publique de l'app (https://... en prod)
AUTH_URL=http://localhost:3000

# --- Mistral ---
MISTRAL_API_KEY=
CHAT_MODEL=mistral-large-latest
TITLE_MODEL=mistral-small-latest
EMBED_MODEL=mistral-embed

# --- RAG ---
# Distance cosine maximale acceptée (1 - similarité). 0.70 ≈ similarité 0.30
RAG_MAX_DISTANCE=0.70
RAG_TOP_K=8
